TINKERPOP_VERSION=3.8.1
ARANGO_TINKERPOP_PROVIDER_VERSION=4.0.0

GREMLIN_SERVER_PORT=8182
GREMLIN_TRAVERSAL_SOURCE=g

# Docker Desktop default. Replace with a Kubernetes service DNS name or routable host as needed.
ARANGO_HOST=host.docker.internal
ARANGO_PORT=8529
ARANGO_USER=root
ARANGO_PASSWORD=change-me
ARANGO_DATABASE=my_db
ARANGO_GRAPH=my_graph
ARANGO_ORPHAN_COLLECTIONS_YAML=
ARANGO_EDGE_DEFINITIONS_YAML="depends_on:[services]->[services]"

# COMPLEX assumes labels map to real ArangoDB collections.
ARANGO_GRAPH_TYPE=COMPLEX

# Keep false for existing graphs unless you explicitly want schema/data-definition changes.
ARANGO_ENABLE_DATA_DEFINITION=false

HELM_RELEASE_NAME=gremlin-arangodb-poc
KUBE_NAMESPACE=gremlin-lab
